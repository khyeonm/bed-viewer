{
  "name": "bed-viewer",
  "version": "1.1.3",
  "description": "Interactive BED file viewer with column detection, color-coded fields, sorting, filtering, and region statistics",
  "extensions": [
    "bed"
  ],
  "entry": "index.js",
  "style": "style.css",
  "data_source": {
    "type": "text",
    "row_count": "grep -cv '^#\\|^track\\|^browser' '{file}'",
    "metadata": "head -1 '{file}'",
    "rows": "grep -v '^#\\|^track\\|^browser' '{file}' | sed -n '{start},{end}p'",
    "col_headers": [],
    "meta_parse": "none",
    "allow_nonzero_exit": false,
    "fallback": [
      {
        "type": "docker",
        "image": "ubuntu:22.04",
        "row_count": "grep -cv '^#\\|^track\\|^browser' '{file}'",
        "metadata": "head -1 '{file}'",
        "rows": "grep -v '^#\\|^track\\|^browser' '{file}' | sed -n '{start},{end}p'",
        "col_headers": [],
        "meta_parse": "none",
        "allow_nonzero_exit": false
      }
    ]
  }
}
